# Liafon Cloud Environment Variables

# ==================== Backend Configuration ====================
NODE_ENV=development
PORT=3000

# ==================== Security ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== PocketBase Database ====================
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@liafon.cloud
POCKETBASE_ADMIN_PASSWORD=admin

# ==================== Redis Cache ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== Ollama AI ====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ==================== Microservices ====================
OCR_SERVICE_URL=http://localhost:5001
VOICE_SERVICE_URL=http://localhost:5002
AI_CHAT_SERVICE_URL=http://localhost:5000

# ==================== Twilio (Optional - SMS Alerts) ====================
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=

# ==================== SMTP Email (Optional) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Liafon Emergency <noreply@liafon.cloud>

# ==================== Logging ====================
LOG_LEVEL=info
LOG_FILE=logs/app.log
